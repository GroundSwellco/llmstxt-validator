# Copy to .env.local and fill in real values. NEVER commit .env.local.
# For Vercel, set these in Project Settings -> Environment Variables.

# Anthropic (for /generate)
ANTHROPIC_API_KEY=

# Stripe (for /checkout and /generate-paid)
STRIPE_SECRET_KEY=

# Supabase auth
# Project URL, e.g. https://xxxxxxxxxxxx.supabase.co
SUPABASE_URL=
# Public anon key - safe in the browser
SUPABASE_ANON_KEY=
# HS256 secret from Supabase -> Settings -> API -> JWT Settings.
# SERVER-ONLY. Never expose to the browser. Rotate if leaked.
SUPABASE_JWT_SECRET=
