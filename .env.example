# Copy to .env.local and fill in real values. NEVER commit .env.local.
# For Vercel, set these in Project Settings -> Environment Variables.

# Anthropic (for /generate)
ANTHROPIC_API_KEY=

# Stripe (for /checkout, /generate-paid, /api/subscribe)
STRIPE_SECRET_KEY=
# Signing secret for the Stripe webhook (Developers -> Webhooks -> your endpoint).
# Server-only. Without this, /api/billing/webhook will reject events.
STRIPE_WEBHOOK_SECRET=

# Supabase auth + billing
# Project URL, e.g. https://xxxxxxxxxxxx.supabase.co
SUPABASE_URL=
# Public anon key - safe in the browser
SUPABASE_ANON_KEY=
# Legacy HS256 secret. Only needed if your Supabase project still uses
# symmetric JWT signing. Newer projects use asymmetric keys and the
# backend auto-fetches them via JWKS - leave this blank.
SUPABASE_JWT_SECRET=
# Service role key from Supabase -> Settings -> API. Bypasses RLS so the
# backend can write subscription state from the Stripe webhook.
# SERVER-ONLY. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=
